# Copy to .env and fill with your values.
NAMESPACE_ID=default
AGENT_ID=frontend
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Optional: override auto hostname shown in inbox()
# MACHINE_NAME=macbook-pro
# Optional: show MCP client type in inbox() online agent list
# CLIENT_TYPE=claude_code
# Optional: show platform in inbox() online agent list
# AGENT_PLATFORM=darwin

# Attachments (Supabase Storage)
# PATCHCORD_ATTACHMENTS_BUCKET=attachments
# PATCHCORD_ATTACHMENT_MAX_BYTES=10485760
# PATCHCORD_ATTACHMENT_URL_EXPIRY_SECONDS=86400
